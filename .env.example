# SadQuant defaults to official Codex CLI auth.
# Run this once before using the codex provider:
#   codex login
SADQUANT_AI_PROVIDER=codex
SADQUANT_MODEL=gpt-5.5

# Optional: override the exact Codex command.
# SADQUANT_CODEX_COMMAND=codex exec --skip-git-repo-check --color never --model gpt-5.5 -

# Optional: generic local CLI provider.
# SADQUANT_AI_PROVIDER=cli
# SADQUANT_CLI_COMMAND=claude -p
# SADQUANT_CLI_TIMEOUT=180

# Optional API-key model providers.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# Optional provider-specific default models.
# SADQUANT_GROQ_MODEL=openai/gpt-oss-20b
# SADQUANT_GEMINI_MODEL=gemini-2.5-pro
# SADQUANT_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional research tools.
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# FUNDA_API_KEY=
# ADANOS_API_KEY=
